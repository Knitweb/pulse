# Route the extensionless relay endpoints RelayTransport posts to
# (/api/relay/{send,fetch,health}, pulse #337) to the live FinField
# store-and-forward implementation, and shield internals from direct access.
RewriteEngine On
RewriteRule ^_(data|mailboxes)(/|$) - [F,L]
RewriteRule ^_(config|lib)\.php$ - [F,L]
RewriteRule ^send$ send.php [L,QSA]
RewriteRule ^fetch$ fetch.php [L,QSA]
RewriteRule ^health$ heartbeat.php [L,QSA]
Options -Indexes
